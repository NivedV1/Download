textarea { resize: vertical; }

table { border-collapse: collapse; border-spacing: 0px; }

td { vertical-align: top; }

.chromeframe { margin: 0.2em 0px; background: rgb(204, 204, 204); color: rgb(0, 0, 0); padding: 0.2em 0px; }

